{
    "name": "beancount/php-parser",
    "version": "1.0.0",
    "description": "PHP library for parsing Beancount double-entry bookkeeping files",
    "type": "library",
    "license": "GPL-3.0",
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpdocumentor/phpdocumentor": "^3.9",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Beancount\\Parser\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Beancount\\Parser\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse src --level=max -c phpstan.neon",
        "lint": "php -l src/**/*.php"
    }
}
