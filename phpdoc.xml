<?xml version="1.0" encoding="UTF-8" ?>
<phpdocumentor
        configVersion="3"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="https://schema.phpdoc.org/phpdocumentor.xsd"
>
    <title>Beancount PHP Parser Documentation</title>
    <paths>
        <output>docs/api</output>
        <cache>build/cache</cache>
    </paths>
    <version number="1.0.0">
        <api format="php">
            <source dsn=".">
                <path>src</path>
            </source>
        </api>
    </version>
</phpdocumentor>
